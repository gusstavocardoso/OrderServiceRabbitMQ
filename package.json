{
  "name": "order-service",
  "version": "1.0.0",
  "description": "Microserviço de pedidos com RabbitMQ e PostgreSQL — projeto de estudos",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --testPathPattern=tests/unit",
    "test:unit": "jest --testPathPattern=tests/unit --verbose",
    "test:integration": "jest --testPathPattern=tests/integration --verbose --runInBand",
    "test:all": "jest --verbose --runInBand",
    "test:coverage": "jest --testPathPattern=tests/unit --coverage --verbose"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}

