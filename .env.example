# Variáveis de ambiente — copie para .env e ajuste conforme necessário
# (O .env NÃO deve ser commitado no Git)

NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=orderuser
DB_PASSWORD=orderpass
DB_NAME=orderdb

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
